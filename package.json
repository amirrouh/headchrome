{
  "private": true,
  "scripts": {
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "pnpm --filter @headchrome/extension build:chrome",
    "build:firefox": "pnpm --filter @headchrome/extension build:firefox",
    "zip": "pnpm zip:chrome && pnpm zip:firefox",
    "zip:chrome": "pnpm --filter @headchrome/extension zip:chrome",
    "zip:firefox": "pnpm --filter @headchrome/extension zip:firefox",
    "lint:firefox": "pnpm --filter @headchrome/extension lint:firefox",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "validate:ids": "node ./scripts/validate-extension-ids.mjs",
    "validate:firefox-publish": "node ./scripts/validate-firefox-publish.mjs",
    "validate:release-tag": "node ./scripts/validate-release-tag.mjs",
    "clean": "pnpm --filter @headchrome/extension clean && rm -rf dist/"
  },
  "pnpm": {
    "overrides": {
      "picomatch": "^4.0.4"
    }
  }
}
